---
import Layout from "../../../layouts/Layout.astro";
import SectionContainer from "../../../components/SectionContainer.astro";
import CaseStudy from "../../../components/CaseStudy.astro";
import { PROJECTS } from "../../../data/projects";
import { useTranslations } from "../../../i18n/utils";

// Only projects with real case study content get a page. While every project has
// hasContent: false, this returns [] and no detail page is built or indexable.
export function getStaticPaths() {
  return PROJECTS.filter((p) => p.hasContent).map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const lang = "en";
const t = useTranslations(lang);
const title = `${project.title} — Fabrizio Contu`;
---

<Layout title={title} lang={lang} description={t.projects[project.descriptionKey]}>
  <main class="px-4 pt-20">
    <SectionContainer id="case-study">
      <CaseStudy lang={lang} project={project} />
    </SectionContainer>
  </main>
</Layout>
