---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const currentYear = new Date().getFullYear();
---

<footer class="mt-16 mb-10 w-full px-4">
  <div
    class="mx-auto flex w-full max-w-3xl flex-col gap-3 border-t border-line pt-6 text-sm text-ink-soft md:flex-row md:items-center md:justify-between"
  >
    <span>© {currentYear} {t.footer.inspired}</span>
    <ul class="flex flex-wrap items-center gap-x-6">
      <li>
        <a
          href="#about"
          class="transition-colors hover:text-terracotta-700">{t.footer.aboutMe}</a
        >
      </li>
      <li>
        <a
          href="mailto:fab.contu@gmail.com"
          class="transition-colors hover:text-terracotta-700">{t.footer.contact}</a
        >
      </li>
    </ul>
  </div>
</footer>
