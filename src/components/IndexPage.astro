---
import Badge from "./Badge.astro";
import Layout from "../layouts/Layout.astro";
import SectionContainer from "./SectionContainer.astro";
import ContactForm from "./ContactForm.astro";
import Projects from "./Projects.astro";
import WorkExperience from "./WorkExperience.astro";
import AboutMe from "./AboutMe.astro";
import GitHubIcon from "./icons/github.astro";
import LinkedinIcon from "./icons/linkedin.astro";
import MailIcon from "./icons/mail.astro";
import SocialPill from "./SocialPill.astro";
import CodeIcon from "./icons/code.astro";
import BriefcaseIcon from "./icons/briefcase.astro";
import CopyIcon from "./icons/copy.astro";
import AboutIcon from "./icons/about.astro";
import Profile from "../assets/Profile_.png";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<Layout title={t.title} lang={lang} description={t.description}>
  <main class="px-4">
    <SectionContainer id="top" aria-label="top" class="py-16 md:py-36">
      <img
        class="rounded-full size-20 mb-6 mt-24 border-2 border-terracotta object-cover"
        src={Profile.src}
        alt={t.hero.profileAlt}
      />

      <div class="mb-4 flex flex-wrap items-center gap-x-4 gap-y-2">
        <a href="#contact" class="transition hover:scale-105">
          <Badge>{t.hero.badge}</Badge>
        </a>
      </div>

      <h1
        class="font-display text-4xl md:text-5xl lg:text-6xl font-semibold tracking-tight text-ink pb-5"
      >
        {t.hero.greeting}
      </h1>
      <h2
        class="max-w-2xl text-lg md:text-xl text-ink-soft text-balance"
        set:html={t.hero.descriptionHtml}
      />

      <nav class="flex flex-wrap items-center gap-y-4 gap-x-4 mt-9">
        <SocialPill href="https://github.com/FabrizioContu">
          <GitHubIcon /> GitHub
        </SocialPill>
        <SocialPill
          href="https://www.linkedin.com/in/fabrizio-contu-9b179b12a/"
        >
          <LinkedinIcon /> LinkedIn
        </SocialPill>
        <SocialPill
          onclick="copyEmail()"
          title={t.hero.copyTitle}
          aria-label={t.hero.copyAriaLabel}
        >
          <CopyIcon /> fab.contu@gmail.com
        </SocialPill>

        <a
          href={t.hero.cvFile}
          download="CV_Fabrizio_Contu.pdf"
          class="inline-flex items-center gap-2 px-5 py-2.5 text-cream-100 bg-terracotta-600 rounded-full shadow-soft transition hover:bg-terracotta-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta-700 focus-visible:ring-offset-2 focus-visible:ring-offset-cream"
          aria-label={t.hero.downloadAriaLabel}
        >
          <MailIcon /> {t.hero.downloadCV}
        </a>
      </nav>

      <div
        id="email-alert"
        role="alert"
        class="hidden mt-6 max-w-md rounded-card border border-line bg-cream-100 p-4 shadow-soft"
      >
        <div class="flex items-start gap-4">
          <span class="text-olive-700">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </span>

          <div class="flex-1">
            <strong class="block font-medium text-ink">
              {t.hero.emailCopiedLabel}
              <span class="text-terracotta-700 font-semibold"
                >fab.contu@gmail.com
              </span>{t.hero.emailCopiedSuffix}
            </strong>
          </div>

          <button
            class="text-ink-soft transition hover:text-ink"
            onclick="dismissAlert()"
            aria-label="Dismiss"
          >
            <span class="sr-only">Dismiss popup</span>

            <svg
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
              class="size-6"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>
      </div>
    </SectionContainer>

    <SectionContainer id="experience" aria-label="experience">
      <h2
        class="font-display text-3xl md:text-4xl font-semibold mb-10 flex gap-x-3 items-center text-ink"
      >
        <BriefcaseIcon class="size-7 text-terracotta-700" />
        {t.sections.experience}
      </h2>
      <WorkExperience lang={lang} />
    </SectionContainer>

    <SectionContainer id="projects" aria-label="projects">
      <h2
        class="font-display text-3xl md:text-4xl font-semibold mb-10 flex gap-x-3 items-center text-ink"
      >
        <CodeIcon class="size-7 text-terracotta-700" />
        {t.sections.projects}
      </h2>
      <Projects lang={lang} />
    </SectionContainer>

    <SectionContainer id="about" aria-label="about">
      <h2
        class="font-display text-3xl md:text-4xl font-semibold mb-8 flex gap-x-3 items-center text-ink"
      >
        <AboutIcon class="size-7 text-terracotta-700" />
        {t.sections.aboutMe}
      </h2>
      <AboutMe lang={lang} />
    </SectionContainer>

    <SectionContainer id="contact" aria-label="contact">
      <ContactForm lang={lang} />
    </SectionContainer>
  </main>
</Layout>

<script is:inline>
  function copyEmail() {
    const email = "fab.contu@gmail.com";
    navigator.clipboard
      .writeText(email)
      .then(() => {
        const alert = document.getElementById("email-alert");
        alert.classList.remove("hidden");
        setTimeout(() => {
          alert.classList.add("hidden");
        }, 3000);
      })
      .catch((err) => {
        console.error("Could not copy the email", err);
      });
  }

  function dismissAlert() {
    const alert = document.getElementById("email-alert");
    alert.classList.add("hidden");
  }
</script>
