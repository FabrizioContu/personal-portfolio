---
import GithubIcon from "./icons/github.astro";
import Link from "./icons/link.astro";
import LinkButton from "./LinkButton.astro";
import Tag from "./Tag.astro";
import { PROJECTS } from "../data/projects";
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const featured = PROJECTS.filter((p) => p.featured);
const others = PROJECTS.filter((p) => !p.featured);
---

<div class="flex flex-col gap-y-16">
  <!-- Featured work — editorial layout with index numbers -->
  <section class="flex flex-col gap-y-12">
    <h3 class="text-sm font-semibold uppercase tracking-widest text-ink-soft">
      {t.sections.featuredWork}
    </h3>
    <div class="flex flex-col gap-y-16">
      {
        featured.map(
          (
            { image, title, descriptionKey, tags, link, github, slug, hasContent },
            i,
          ) => (
            <article class="group flex flex-col gap-6 md:flex-row md:gap-8">
              <div class="w-full md:w-1/2">
                <div class="overflow-hidden rounded-card border border-line shadow-soft transition duration-500 ease-out group-hover:-translate-y-1">
                  <img
                    alt=""
                    class="h-56 w-full object-cover object-top transition duration-500 sm:h-full group-hover:scale-105"
                    loading="lazy"
                    src={image}
                  />
                </div>
              </div>

              <div class="w-full md:w-1/2 md:max-w-lg">
                <span class="font-display text-2xl text-terracotta-700/70">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <h4 class="font-display text-2xl font-semibold text-ink">
                  {title}
                </h4>
                <ul class="flex flex-row flex-wrap gap-2 my-3">
                  {tags.map((tag) => (
                    <li>
                      <Tag tag={tag} />
                    </li>
                  ))}
                </ul>

                <p class="text-ink-soft">{t.projects[descriptionKey]}</p>

                <footer class="flex flex-wrap items-end justify-start mt-5 gap-x-4 gap-y-2">
                  {github && (
                    <LinkButton href={github}>
                      <GithubIcon class="size-5" />
                      {t.projects.viewCode}
                    </LinkButton>
                  )}
                  {link && (
                    <LinkButton href={link}>
                      <Link class="size-4" />
                      {t.projects.visitSite}
                    </LinkButton>
                  )}
                  {hasContent && (
                    <a
                      href={`/${lang}/projects/${slug}`}
                      class="inline-flex max-w-fit items-center justify-center gap-2 rounded-full bg-terracotta-600 px-4 py-2 text-base text-cream-100 transition hover:bg-terracotta-700 focus:outline-none focus-visible:ring-2 focus-visible:ring-terracotta-700 focus-visible:ring-offset-2 focus-visible:ring-offset-cream"
                    >
                      <Link class="size-4" />
                      {t.projects.viewCase}
                    </a>
                  )}
                </footer>
              </div>
            </article>
          ),
        )
      }
    </div>
  </section>

  <!-- Other projects — compact list -->
  <section class="flex flex-col gap-y-8">
    <h3 class="text-sm font-semibold uppercase tracking-widest text-ink-soft">
      {t.sections.otherProjects}
    </h3>
    <div class="grid gap-5 sm:grid-cols-2">
      {
        others.map(({ title, descriptionKey, tags, link, github }) => (
          <article class="flex h-full flex-col rounded-card border border-line bg-cream-100 p-5 shadow-soft transition duration-300 hover:-translate-y-1">
            <h4 class="font-display text-xl font-semibold text-ink">{title}</h4>
            <p class="mt-2 flex-1 text-sm text-ink-soft">
              {t.projects[descriptionKey]}
            </p>
            <ul class="flex flex-row flex-wrap gap-2 mt-4">
              {tags.map((tag) => (
                <li>
                  <Tag tag={tag} />
                </li>
              ))}
            </ul>
            <footer class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2">
              {github && (
                <LinkButton href={github}>
                  <GithubIcon class="size-5" />
                  {t.projects.viewCode}
                </LinkButton>
              )}
              {link && (
                <LinkButton href={link}>
                  <Link class="size-4" />
                  {t.projects.visitSite}
                </LinkButton>
              )}
            </footer>
          </article>
        ))
      }
    </div>
  </section>
</div>
