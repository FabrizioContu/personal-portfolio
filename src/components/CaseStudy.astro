---
import GithubIcon from "./icons/github.astro";
import Link from "./icons/link.astro";
import LinkButton from "./LinkButton.astro";
import Tag from "./Tag.astro";
import { useTranslations, type Lang } from "../i18n/utils";
import type { Project } from "../data/projects";

interface Props {
  lang: Lang;
  project: Project;
}

const { lang, project } = Astro.props;
const t = useTranslations(lang);
const labels = t.caseStudy;
const content = t.caseStudies[project.slug as keyof typeof t.caseStudies];

const sections = [
  { heading: labels.problem, body: content.problem },
  { heading: labels.solution, body: content.solution },
  { heading: labels.result, body: content.result },
];
---

<article class="flex flex-col gap-y-8">
  <a
    href={`/${lang}/#projects`}
    class="text-sm text-teal-600 dark:text-teal-400 hover:underline w-fit"
  >
    ← {labels.back}
  </a>

  <header class="flex flex-col gap-y-4">
    <h1 class="text-3xl md:text-4xl font-bold dark:text-white">{project.title}</h1>
    <p class="text-lg text-gray-700 dark:text-gray-300">
      {t.projects[project.descriptionKey]}
    </p>
    <ul class="flex flex-row flex-wrap gap-2">
      {project.tags.map((tag) => (
        <li>
          <Tag tag={tag} />
        </li>
      ))}
    </ul>
  </header>

  {
    sections.map((section) => (
      <section class="flex flex-col gap-y-2">
        <h2 class="text-2xl font-semibold text-gray-700 dark:text-gray-300">
          {section.heading}
        </h2>
        <p class="text-gray-700 dark:text-gray-400">{section.body}</p>
      </section>
    ))
  }

  <footer class="flex flex-wrap items-end justify-start mt-4 gap-x-4 gap-y-2">
    {project.github && (
      <LinkButton href={project.github}>
        <GithubIcon class="size-6" />
        {t.projects.viewCode}
      </LinkButton>
    )}
    {project.link && (
      <LinkButton href={project.link}>
        <Link class="size-4" />
        {t.projects.visitSite}
      </LinkButton>
    )}
  </footer>
</article>
