---
import GithubIcon from "./icons/github.astro";
import Link from "./icons/link.astro";
import LinkButton from "./LinkButton.astro";
import Tag from "./Tag.astro";
import { useTranslations, type Lang } from "../i18n/utils";
import type { Project } from "../data/projects";

interface Props {
  lang: Lang;
  project: Project;
}

const { lang, project } = Astro.props;
const t = useTranslations(lang);
const labels = t.caseStudy;
const content = t.caseStudies[project.slug as keyof typeof t.caseStudies];
const gallery = project.gallery ?? [];
---

<article class="flex flex-col gap-y-10">
  <a
    href={`/${lang}/#projects`}
    class="text-sm text-terracotta-700 hover:underline w-fit"
  >
    ← {labels.back}
  </a>

  <header class="flex flex-col gap-y-4">
    <h1 class="font-display text-3xl md:text-4xl font-semibold text-ink">{project.title}</h1>
    <p class="text-lg text-ink-soft">
      {t.projects[project.descriptionKey]}
    </p>
    <ul class="flex flex-row flex-wrap gap-2">
      {project.tags.map((tag) => (
        <li>
          <Tag tag={tag} />
        </li>
      ))}
    </ul>
  </header>

  {/* Gallery — screenshots of the live site. Placeholder until real images exist. */}
  <section aria-label={labels.gallery}>
    {gallery.length > 0 ? (
      <div class="grid gap-4 sm:grid-cols-2">
        {gallery.map((src) => (
          <img
            src={src}
            alt=""
            loading="lazy"
            class="w-full rounded-card border border-line shadow-soft"
          />
        ))}
      </div>
    ) : (
      <div class="flex items-center justify-center rounded-card border border-dashed border-line bg-cream-200 p-10 text-center text-sm text-ink-soft">
        {labels.galleryPlaceholder}
      </div>
    )}
  </section>

  <section class="flex flex-col gap-y-2">
    <h2 class="font-display text-2xl font-semibold text-ink">
      {labels.problem}
    </h2>
    <p class="text-ink-soft">{content.problem}</p>
  </section>

  <section class="flex flex-col gap-y-2">
    <h2 class="font-display text-2xl font-semibold text-ink">
      {labels.solution}
    </h2>
    <p class="text-ink-soft">{content.solution}</p>
  </section>

  {/* Metrics — never invent these; placeholders until real data is available. */}
  {content.metrics.length > 0 && (
    <section class="flex flex-col gap-y-4">
      <h2 class="font-display text-2xl font-semibold text-ink">
        {labels.metrics}
      </h2>
      <dl class="grid gap-4 sm:grid-cols-3">
        {content.metrics.map((metric) => (
          <div class="rounded-card border border-line bg-cream-100 p-6 text-center shadow-soft">
            <dt class="sr-only">{metric.label}</dt>
            <dd class="font-display text-3xl font-bold text-terracotta-700">
              {metric.value}
            </dd>
            <p class="mt-1 text-sm text-ink-soft">
              {metric.label}
            </p>
          </div>
        ))}
      </dl>
    </section>
  )}

  <section class="flex flex-col gap-y-2">
    <h2 class="font-display text-2xl font-semibold text-ink">
      {labels.result}
    </h2>
    <p class="text-ink-soft">{content.result}</p>
  </section>

  <footer class="flex flex-wrap items-end justify-start mt-4 gap-x-4 gap-y-2">
    {project.github && (
      <LinkButton href={project.github}>
        <GithubIcon class="size-6" />
        {t.projects.viewCode}
      </LinkButton>
    )}
    {project.link && (
      <LinkButton href={project.link}>
        <Link class="size-4" />
        {t.projects.visitSite}
      </LinkButton>
    )}
  </footer>
</article>
