---
import { TESTIMONIALS } from "../data/testimonials";

// No `lang` prop: testimonials are quoted in their original language, and the
// section heading is rendered by the parent (IndexPage).
---

<div class="grid gap-6 md:grid-cols-3">
  {
    TESTIMONIALS.map((item) => (
      <figure class="flex flex-col justify-between rounded-card border border-line bg-cream-100 p-6 shadow-soft">
        <blockquote class="text-ink-soft">
          “{item.text}”
        </blockquote>
        <figcaption class="mt-4">
          <span class="block font-semibold text-ink">
            {item.name}
          </span>
          <span class="block text-sm text-ink-soft">
            {item.role}
          </span>
        </figcaption>
      </figure>
    ))
  }
</div>
