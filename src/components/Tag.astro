---
import ReactIcon from "./icons/react.astro";
import NextjsIcon from "./icons/nextjs.astro";
import WordpressIcon from "./icons/wordpress.astro";
import TailwindIcon from "./icons/tailwind.astro";
import TypescriptIcon from "./icons/typescript.astro";
import HtmlIcon from "./icons/html.astro";
import BootstrapIcon from "./icons/bootstrap.astro";
import AstroIcon from "./icons/astro.astro";
import PhpIcon from "./icons/php.astro";
import type { TagKey } from "../data/projects";

const TAGS = {
  REACT: { name: "React.js", icon: ReactIcon },
  TAILWIND: { name: "Tailwind CSS", icon: TailwindIcon },
  TYPESCRIPT: { name: "TypeScript", icon: TypescriptIcon },
  BOOTSTRAP: { name: "Bootstrap", icon: BootstrapIcon },
  HTML: { name: "HTML5", icon: HtmlIcon },
  ASTRO: { name: "astro", icon: AstroIcon },
  NEXTJS: { name: "Next.js", icon: NextjsIcon },
  WORDPRESS: { name: "WordPress", icon: WordpressIcon },
  PHP: { name: "PHP", icon: PhpIcon },
} satisfies Record<TagKey, { name: string; icon: unknown }>;

interface Props {
  tag: TagKey;
}

const { tag } = Astro.props;
const { name, icon: Icon } = TAGS[tag];
---

<span
  class="flex justify-center items-center gap-x-2 rounded-full border border-line bg-cream-200 text-ink-soft text-xs py-1 px-2.5"
>
  <Icon class="size-4" />
  {name}
</span>
