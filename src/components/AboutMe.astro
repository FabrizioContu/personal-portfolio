---
import { useTranslations, type Lang } from "../i18n/utils";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section
  class="flex flex-col justify-center items-center gap-x-10 gap-y-6 md:flex-row"
>
  <div class="text-ink-soft text-lg leading-relaxed">
    <p class="mb-4" set:html={t.about.p1Html} />
    <p class="mb-4" set:html={t.about.p2Html} />
    <p>{t.about.p3}</p>
  </div>
  <img
    src="/me.webp"
    alt={t.hero.profileAlt}
    class="size-48 shrink-0 rounded-full border-2 border-terracotta object-cover shadow-soft"
  />
</section>
